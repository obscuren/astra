---
const title = "Astra";
const description = "A sci-fi roguelike dungeon crawler set in the far future. Travel across star systems, crawl asteroid dungeons, and journey to the supermassive black hole at the center of the galaxy.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Space+Grotesk:wght@400;600;700&display=swap');

      :root {
        --bg: #06080f;
        --surface: #0d1117;
        --surface-2: #151b27;
        --border: #1c2333;
        --text: #c9d1d9;
        --text-dim: #6e7681;
        --accent: #f0c040;
        --accent-dim: #9e7c1a;
        --blue: #58a6ff;
        --green: #3fb950;
        --red: #f85149;
        --cyan: #56d4dd;
        --mono: 'JetBrains Mono', 'Fira Code', monospace;
        --sans: 'Space Grotesk', system-ui, sans-serif;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        line-height: 1.6;
        min-height: 100vh;
        overflow-x: hidden;
      }

      /* Starfield background */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
          radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,0.3), transparent),
          radial-gradient(1px 1px at 40% 70%, rgba(255,255,255,0.2), transparent),
          radial-gradient(1px 1px at 60% 20%, rgba(255,255,255,0.3), transparent),
          radial-gradient(1px 1px at 80% 50%, rgba(255,255,255,0.15), transparent),
          radial-gradient(1.5px 1.5px at 10% 80%, rgba(240,192,64,0.4), transparent),
          radial-gradient(1.5px 1.5px at 90% 10%, rgba(88,166,255,0.4), transparent),
          radial-gradient(1px 1px at 50% 50%, rgba(255,255,255,0.2), transparent),
          radial-gradient(1px 1px at 30% 90%, rgba(255,255,255,0.15), transparent),
          radial-gradient(1px 1px at 70% 40%, rgba(255,255,255,0.25), transparent),
          radial-gradient(1px 1px at 15% 55%, rgba(255,255,255,0.2), transparent),
          radial-gradient(1px 1px at 85% 75%, rgba(255,255,255,0.15), transparent),
          radial-gradient(1px 1px at 45% 15%, rgba(255,255,255,0.2), transparent);
        pointer-events: none;
        z-index: 0;
      }

      .container {
        position: relative;
        z-index: 1;
        max-width: 900px;
        margin: 0 auto;
        padding: 0 24px;
      }

      /* Hero */
      .hero {
        padding: 100px 0 80px;
        text-align: center;
      }

      .hero-ascii {
        font-family: var(--mono);
        font-size: 14px;
        line-height: 1.3;
        color: var(--accent);
        margin-bottom: 32px;
        letter-spacing: 1px;
        white-space: pre;
        display: inline-block;
        text-shadow: 0 0 20px rgba(240, 192, 64, 0.3);
      }

      .hero h1 {
        font-family: var(--sans);
        font-size: 3.5rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 16px;
        letter-spacing: -0.5px;
      }

      .hero .tagline {
        font-size: 1.25rem;
        color: var(--text-dim);
        max-width: 560px;
        margin: 0 auto 40px;
      }

      .hero-links {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border-radius: 8px;
        font-family: var(--mono);
        font-size: 0.9rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
      }

      .btn-primary {
        background: var(--accent);
        color: var(--bg);
      }
      .btn-primary:hover {
        background: #ffd04a;
        transform: translateY(-1px);
        box-shadow: 0 4px 20px rgba(240, 192, 64, 0.3);
      }

      .btn-secondary {
        background: var(--surface-2);
        color: var(--text);
        border: 1px solid var(--border);
      }
      .btn-secondary:hover {
        background: var(--border);
        transform: translateY(-1px);
      }

      /* Terminal demo */
      .terminal {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        margin: 60px 0;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.4);
      }

      .terminal-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        background: var(--surface-2);
        border-bottom: 1px solid var(--border);
      }

      .terminal-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
      }
      .terminal-dot.red { background: var(--red); }
      .terminal-dot.yellow { background: var(--accent); }
      .terminal-dot.green { background: var(--green); }

      .terminal-title {
        flex: 1;
        text-align: center;
        font-family: var(--mono);
        font-size: 0.8rem;
        color: var(--text-dim);
      }

      .terminal-body {
        padding: 24px;
        font-family: var(--mono);
        font-size: 13px;
        line-height: 1.5;
        overflow-x: auto;
      }

      .terminal-body pre {
        white-space: pre;
        margin: 0;
      }

      .t-wall { color: #e6e6e6; }
      .t-floor { color: #6e7681; }
      .t-player { color: var(--accent); font-weight: bold; }
      .t-explored { color: var(--blue); }
      .t-dim { color: #3d4450; }
      .t-ui { color: #8b949e; }
      .t-hp { color: var(--green); }
      .t-label { color: var(--text-dim); }
      .t-cyan { color: var(--cyan); }
      .t-blue { color: var(--blue); }
      .t-yellow { color: var(--accent); }
      .t-tab-active { color: var(--accent); font-weight: bold; }
      .t-tab { color: #3d4450; }

      /* Features */
      .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin: 0 0 80px;
      }

      .feature {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 28px;
        transition: border-color 0.2s;
      }
      .feature:hover {
        border-color: var(--accent-dim);
      }

      .feature-icon {
        font-family: var(--mono);
        font-size: 1.5rem;
        margin-bottom: 12px;
        color: var(--accent);
      }

      .feature h3 {
        font-size: 1.1rem;
        color: #fff;
        margin-bottom: 8px;
      }

      .feature p {
        font-size: 0.9rem;
        color: var(--text-dim);
        line-height: 1.5;
      }

      /* Lore section */
      .lore {
        margin: 0 0 80px;
        padding: 48px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 12px;
        position: relative;
        overflow: hidden;
      }

      .lore::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent), transparent);
      }

      .lore h2 {
        font-size: 1.8rem;
        color: #fff;
        margin-bottom: 20px;
      }

      .lore p {
        color: var(--text-dim);
        font-size: 1rem;
        margin-bottom: 16px;
        max-width: 700px;
      }
      .lore p:last-child {
        margin-bottom: 0;
      }

      .lore .highlight {
        color: var(--accent);
        font-weight: 600;
      }

      /* Tech section */
      .tech {
        margin: 0 0 80px;
        text-align: center;
      }

      .tech h2 {
        font-size: 1.8rem;
        color: #fff;
        margin-bottom: 12px;
      }

      .tech .sub {
        color: var(--text-dim);
        margin-bottom: 32px;
      }

      .tech-grid {
        display: flex;
        gap: 12px;
        justify-content: center;
        flex-wrap: wrap;
      }

      .tech-tag {
        font-family: var(--mono);
        font-size: 0.85rem;
        padding: 8px 16px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 6px;
        color: var(--cyan);
      }

      /* Footer */
      footer {
        padding: 40px 0;
        text-align: center;
        border-top: 1px solid var(--border);
        color: var(--text-dim);
        font-size: 0.85rem;
      }

      footer a {
        color: var(--accent);
        text-decoration: none;
      }
      footer a:hover {
        text-decoration: underline;
      }

      @media (max-width: 600px) {
        .hero { padding: 60px 0 40px; }
        .hero h1 { font-size: 2.5rem; }
        .hero-ascii { font-size: 10px; }
        .terminal-body { font-size: 11px; padding: 16px; }
        .lore { padding: 28px; }
      }
    </style>
  </head>
  <body>
    <div class="container">
      <section class="hero">
        <div class="hero-ascii" aria-hidden="true">{`        .            *                .          |
   *         .              .                .  -o-
        _        _                   *           |
  .    / \\   ___| |_ _ __ __ _           .
      / _ \\ / __| __| '__/ _\` |   .
 *   / ___ \\\\__ \\ |_| | | (_| |        *
    /_/   \\_\\___/\\__|_|  \\__,_|  .
         .          *       .          .
   .            .                 *`}</div>
        <h1>Astra</h1>
        <p class="tagline">A sci-fi roguelike set in the far future. Explore asteroid dungeons, upgrade your starship, and journey to Sagittarius&nbsp;A*.</p>
        <div class="hero-links">
          <a class="btn btn-primary" href="https://github.com/obscuren/astra">Source Code</a>
          <a class="btn btn-secondary" href="https://github.com/obscuren/astra/releases">Releases</a>
        </div>
      </section>

      <div class="terminal">
        <div class="terminal-bar">
          <span class="terminal-dot red"></span>
          <span class="terminal-dot yellow"></span>
          <span class="terminal-dot green"></span>
          <span class="terminal-title">astra --terminal</span>
        </div>
        <div class="terminal-body">
          <pre><span class="t-label">LVL:</span>1 <span class="t-label">::</span> <span class="t-label">T:</span>20~ <span class="t-label">::</span> <span class="t-hp">Satiated</span> <span class="t-label">::</span> <span class="t-yellow">0$</span> <span class="t-cyan">&lt;&lt;&gt;&gt;&lt;&lt;&gt;&gt;&lt;&lt;&gt;&gt;&lt;&lt;&gt;&gt;</span> <span class="t-label">QN:</span>100 <span class="t-label">::</span> <span class="t-label">AV:</span><span class="t-blue">1</span> <span class="t-label">::</span> <span class="t-label">DV:</span><span class="t-blue">5</span> <span class="t-label">::</span> The Heavens Above
<span class="t-label">HP:</span> <span class="t-hp">10/10</span>  <span class="t-hp">[===================]</span>        <span class="t-ui">|</span> <span class="t-tab-active">[Messages]</span> <span class="t-tab">[Inventory]</span> <span class="t-tab">[Equip]</span> <span class="t-tab">[Ship]</span>
<span class="t-label">XP:</span> <span class="t-cyan"> 0/100</span> <span class="t-dim">[-------------------]</span>        <span class="t-ui">|</span> <span class="t-dim">--------------------------------------</span>
  <span class="t-explored">################</span>                      <span class="t-ui">|</span> :: Welcome aboard, commander. Your
  <span class="t-explored">#</span><span class="t-floor">..............</span><span class="t-explored">#</span>                      <span class="t-ui">|</span>    journey to Sgr A* begins.
  <span class="t-wall">#</span><span class="t-floor">..............</span><span class="t-wall">#</span>     <span class="t-dim">.</span>    <span class="t-dim">*</span>           <span class="t-ui">|</span> :: You are docked at The Heavens
  <span class="t-wall">#</span><span class="t-floor">.....</span><span class="t-player">@</span><span class="t-floor">........</span><span class="t-wall">#</span>                      <span class="t-ui">|</span>    Above, the space station
  <span class="t-wall">#</span><span class="t-floor">..............</span><span class="t-wall">#</span>                      <span class="t-ui">|</span>    orbiting Jupiter.
  <span class="t-wall">#</span><span class="t-floor">..............</span><span class="t-wall">#</span>                      <span class="t-ui">|</span>
  <span class="t-wall">####</span><span class="t-floor">...</span><span class="t-wall">###########</span>                    <span class="t-ui">|</span>
       <span class="t-explored">.</span>              <span class="t-dim">*</span>                 <span class="t-ui">|</span>
    <span class="t-explored">########</span>                            <span class="t-ui">|</span>
    <span class="t-explored">#</span><span class="t-blue">......</span><span class="t-explored">#</span>                            <span class="t-ui">|</span>
<span class="t-label">EFFECTS:</span> <span class="t-dim">[none]</span>          <span class="t-label">TARGET:</span> <span class="t-dim">[none]</span>
<span class="t-label">ABILITIES:</span> <span class="t-dim">[reserved]</span></pre>
        </div>
      </div>

      <div class="features">
        <div class="feature">
          <div class="feature-icon">#</div>
          <h3>Procedural Dungeons</h3>
          <p>Every asteroid, space station, and dungeon is randomly generated. Rooms, corridors, and secrets are never the same twice.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">*</div>
          <h3>FOV &amp; Exploration</h3>
          <p>Recursive shadowcasting reveals the world around you. Lit rooms glow in the distance; dark corridors demand caution.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">~</div>
          <h3>Interstellar Travel</h3>
          <p>Navigate between star systems via black holes. Upgrade your Hyperspace Engine and Navi Computer to plot longer routes.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">+</div>
          <h3>Gear &amp; Upgrades</h3>
          <p>Equip weapons, improve stats, and upgrade your starship. Your view radius, hull strength, and jump range all grow with you.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">$</div>
          <h3>Trade &amp; Barter</h3>
          <p>Space stations host shopkeepers from across the galaxy. Some don't speak your language. All want your credits.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">@</div>
          <h3>Classic Roguelike</h3>
          <p>Turn-based, permadeath, and ASCII-rendered. Inspired by Rogue, NetHack, Angband, and Moria &mdash; but set among the stars.</p>
        </div>
      </div>

      <section class="lore">
        <h2>The Story</h2>
        <p>All stories begin on <span class="highlight">The Heavens Above</span>, a space station orbiting Jupiter. From here, you'll dock your starship, trade with merchants, and prepare for the journey of a lifetime.</p>
        <p>Your goal: reach the center of the galaxy and enter <span class="highlight">Sagittarius A*</span>, the supermassive black hole. Those who survive the crossing are reborn in a new universe &mdash; their starship intact, their knowledge of the cosmos infinite.</p>
        <p>Space is vast. Asteroid belts hide dungeons filled with ancient tech, hostile creatures, and forgotten relics. Star systems are generated from the real map of the universe, connected by black hole jump points that only a Navi Computer can calculate.</p>
      </section>

      <section class="tech">
        <h2>Built With</h2>
        <p class="sub">C++20, zero dependencies for terminal mode</p>
        <div class="tech-grid">
          <span class="tech-tag">C++20</span>
          <span class="tech-tag">CMake</span>
          <span class="tech-tag">POSIX Terminal</span>
          <span class="tech-tag">SDL3 (optional)</span>
          <span class="tech-tag">Recursive Shadowcasting</span>
          <span class="tech-tag">Procedural Generation</span>
        </div>
      </section>

      <footer>
        <p>Astra is open source &mdash; <a href="https://github.com/obscuren/astra">view on GitHub</a></p>
      </footer>
    </div>
  </body>
</html>
