---
const title = "ASTRA — Sci-Fi Roguelike";
const description = "A sci-fi roguelike dungeon crawler. Command a starship, explore the unknown, navigate through black holes, and reach Sagittarius A* at the heart of the galaxy.";
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style is:inline>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --void: #050508;
  --deep: #0a0a10;
  --panel: #0c0c14;
  --border: #1a1a2e;
  --dim: #2a2a3e;
  --muted: #4a4a6a;
  --text: #8888aa;
  --light: #c0c0d8;
  --white: #e8e8f0;
  --cyan: #00e5ff;
  --cyan-dim: #00e5ff33;
  --cyan-glow: #00e5ff15;
  --amber: #ffb300;
  --amber-dim: #ffb30033;
  --green: #00e676;
  --green-dim: #00e67633;
  --red: #ff1744;
  --magenta: #e040fb;
  --mono: 'Share Tech Mono', monospace;
  --display: 'Rajdhani', sans-serif;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
}

body {
  background: var(--void);
  color: var(--text);
  font-family: var(--mono);
  overflow-x: hidden;
  overflow-y: hidden;
  -webkit-font-smoothing: antialiased;
}

body.booted {
  overflow-y: auto;
}

/* ── Scanline overlay ── */
body::after {
  content: '';
  position: fixed;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 0, 0, 0.08) 2px,
    rgba(0, 0, 0, 0.08) 4px
  );
  pointer-events: none;
  z-index: 9999;
}

/* ── Starfield canvas ── */
#starfield {
  position: fixed;
  inset: 0;
  z-index: 0;
}

/* ── Main content ── */
.content {
  position: relative;
  z-index: 1;
}

/* ── Boot sequence ── */
.boot-screen {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: var(--void);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  transition: opacity 0.8s ease, visibility 0.8s ease;
}

.boot-screen.done {
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
}

.boot-text {
  font-family: var(--mono);
  font-size: 0.8rem;
  color: var(--cyan);
  text-align: left;
  width: 520px;
  max-width: 90vw;
  line-height: 1.6;
}

.boot-text .line {
  opacity: 0;
  transform: translateY(4px);
}

.boot-text .line.visible {
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.3s, transform 0.3s;
}

.boot-text .ok { color: var(--green); }
.boot-text .warn { color: var(--amber); }
.boot-text .label { color: var(--muted); }

.cursor-blink {
  display: inline-block;
  width: 8px;
  height: 14px;
  background: var(--cyan);
  animation: blink 1s step-end infinite;
  vertical-align: text-bottom;
  margin-left: 2px;
}

@keyframes blink {
  50% { opacity: 0; }
}

/* ── Hero ── */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 2rem;
  text-align: center;
}

.hero-ascii {
  font-family: var(--mono);
  font-size: clamp(0.45rem, 1.2vw, 0.75rem);
  line-height: 1.2;
  color: var(--cyan);
  white-space: pre;
  text-shadow: 0 0 20px var(--cyan-dim), 0 0 40px rgba(0, 229, 255, 0.08);
  opacity: 0;
  transform: scale(0.95);
  transition: opacity 1s ease 0.3s, transform 1s ease 0.3s;
  margin-bottom: 2rem;
}

.hero-ascii.visible {
  opacity: 1;
  transform: scale(1);
}

.hero-title {
  font-family: var(--display);
  font-weight: 700;
  font-size: clamp(3rem, 8vw, 7rem);
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--white);
  text-shadow: 0 0 60px var(--cyan-dim), 0 0 120px rgba(0, 229, 255, 0.05);
  margin-bottom: 0.5rem;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.8s ease 0.6s, transform 0.8s ease 0.6s;
}

.hero-title.visible {
  opacity: 1;
  transform: translateY(0);
}

.hero-subtitle {
  font-family: var(--mono);
  font-size: clamp(0.7rem, 1.5vw, 0.9rem);
  color: var(--muted);
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin-bottom: 3rem;
  opacity: 0;
  transition: opacity 0.8s ease 1s;
}

.hero-subtitle.visible { opacity: 1; }

.hero-tagline {
  font-family: var(--mono);
  font-size: clamp(0.85rem, 1.8vw, 1.05rem);
  color: var(--light);
  max-width: 600px;
  line-height: 1.7;
  margin-bottom: 3rem;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.8s ease 1.2s, transform 0.8s ease 1.2s;
}

.hero-tagline.visible {
  opacity: 1;
  transform: translateY(0);
}

.hero-tagline em {
  color: var(--cyan);
  font-style: normal;
}

.hero-actions {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
  justify-content: center;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.8s ease 1.5s, transform 0.8s ease 1.5s;
}

.hero-actions.visible {
  opacity: 1;
  transform: translateY(0);
}

.btn {
  font-family: var(--mono);
  font-size: 0.85rem;
  padding: 0.8rem 2rem;
  border: 1px solid var(--cyan);
  background: transparent;
  color: var(--cyan);
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

.btn:hover {
  background: var(--cyan);
  color: var(--void);
  box-shadow: 0 0 30px var(--cyan-dim), inset 0 0 30px rgba(0, 229, 255, 0.1);
}

.btn.secondary {
  border-color: var(--dim);
  color: var(--muted);
}

.btn.secondary:hover {
  border-color: var(--amber);
  color: var(--amber);
  background: transparent;
  box-shadow: 0 0 30px var(--amber-dim);
}

/* ── Scroll indicator ── */
.scroll-indicator {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  color: var(--dim);
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  animation: float 3s ease-in-out infinite;
  opacity: 0;
  transition: opacity 0.8s ease 2s;
}

.scroll-indicator.visible { opacity: 1; }

.scroll-indicator::after {
  content: '';
  display: block;
  width: 1px;
  height: 30px;
  background: linear-gradient(to bottom, var(--dim), transparent);
  margin: 0.8rem auto 0;
}

@keyframes float {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}

/* ── Section styling ── */
section {
  padding: 6rem 2rem;
  max-width: 1100px;
  margin: 0 auto;
}

.section-divider {
  width: 100%;
  max-width: 1100px;
  margin: 0 auto;
  border: none;
  border-top: 1px solid var(--border);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 3rem;
}

.section-tag {
  font-family: var(--mono);
  font-size: 0.65rem;
  color: var(--void);
  background: var(--cyan);
  padding: 0.2rem 0.6rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  flex-shrink: 0;
}

.section-tag.amber { background: var(--amber); }
.section-tag.green { background: var(--green); }
.section-tag.magenta { background: var(--magenta); }

.section-title {
  font-family: var(--display);
  font-weight: 600;
  font-size: clamp(1.4rem, 3vw, 1.8rem);
  color: var(--white);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

/* ── Terminal block ── */
.terminal {
  background: var(--deep);
  border: 1px solid var(--border);
  padding: 2rem;
  margin-bottom: 3rem;
  position: relative;
  overflow: hidden;
}

.terminal::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--cyan), transparent);
  opacity: 0.4;
}

.terminal-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
  padding-bottom: 1rem;
  border-bottom: 1px solid var(--border);
}

.terminal-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--dim);
}

.terminal-dot.r { background: var(--red); }
.terminal-dot.y { background: var(--amber); }
.terminal-dot.g { background: var(--green); }

.terminal-path {
  font-size: 0.7rem;
  color: var(--muted);
  margin-left: 0.5rem;
}

.terminal pre {
  font-family: var(--mono);
  font-size: 0.8rem;
  line-height: 1.7;
  color: var(--light);
  overflow-x: auto;
}

.terminal pre .prompt { color: var(--cyan); }
.terminal pre .comment { color: var(--muted); }
.terminal pre .flag { color: var(--amber); }
.terminal pre .string { color: var(--green); }
.terminal pre .output { color: var(--text); }

/* ── Features grid ── */
.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.5rem;
}

.feature-card {
  background: var(--deep);
  border: 1px solid var(--border);
  padding: 2rem;
  position: relative;
  overflow: hidden;
  transition: border-color 0.3s ease, transform 0.3s ease;
}

.feature-card:hover {
  border-color: var(--dim);
  transform: translateY(-2px);
}

.feature-card::before {
  content: attr(data-index);
  position: absolute;
  top: -0.5rem;
  right: 1rem;
  font-family: var(--display);
  font-weight: 700;
  font-size: 4rem;
  color: var(--border);
  line-height: 1;
  pointer-events: none;
}

.feature-glyph {
  font-size: 1.5rem;
  margin-bottom: 1rem;
  display: block;
}

.feature-name {
  font-family: var(--display);
  font-weight: 600;
  font-size: 1.1rem;
  color: var(--white);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 0.8rem;
}

.feature-desc {
  font-size: 0.8rem;
  line-height: 1.7;
  color: var(--text);
}

/* ── Lore section ── */
.lore-block {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}

.lore-text {
  font-size: 0.85rem;
  line-height: 1.9;
  color: var(--text);
}

.lore-text p { margin-bottom: 1.5rem; }
.lore-text em {
  color: var(--light);
  font-style: normal;
}

.lore-ascii {
  font-family: var(--mono);
  font-size: 0.55rem;
  line-height: 1.15;
  color: var(--dim);
  white-space: pre;
  text-align: center;
  padding: 2rem;
  border: 1px solid var(--border);
  background: var(--deep);
  overflow: hidden;
}

.lore-ascii .highlight { color: var(--cyan); }
.lore-ascii .star { color: var(--amber); }

/* ── Races section ── */
.races-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
}

.race-card {
  border: 1px solid var(--border);
  padding: 1.5rem;
  background: var(--deep);
  transition: border-color 0.3s;
}

.race-card:hover {
  border-color: var(--dim);
}

.race-glyph {
  font-size: 2rem;
  margin-bottom: 0.5rem;
  display: block;
}

.race-name {
  font-family: var(--display);
  font-weight: 600;
  font-size: 1rem;
  color: var(--white);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.3rem;
}

.race-trait {
  font-size: 0.7rem;
  color: var(--muted);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 0.8rem;
}

.race-desc {
  font-size: 0.75rem;
  line-height: 1.6;
  color: var(--text);
}

.race-card .race-glyph.human { color: var(--cyan); }
.race-card .race-glyph.veldrani { color: #7c4dff; }
.race-card .race-glyph.kreth { color: var(--amber); }
.race-card .race-glyph.sylphari { color: var(--green); }
.race-card .race-glyph.stellari { color: #ffd54f; }

/* ── Classes grid ── */
.classes-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1rem;
}

.class-card {
  border: 1px solid var(--border);
  padding: 1.5rem;
  background: var(--deep);
  transition: border-color 0.3s;
}

.class-card:hover {
  border-color: var(--dim);
}

.class-glyph {
  font-size: 2rem;
  margin-bottom: 0.5rem;
  display: block;
  color: var(--cyan);
}

.class-name {
  font-family: var(--display);
  font-weight: 600;
  font-size: 1rem;
  color: var(--white);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.3rem;
}

.class-trait {
  font-size: 0.7rem;
  color: var(--muted);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 0.8rem;
}

.class-desc {
  font-size: 0.75rem;
  line-height: 1.6;
  color: var(--text);
}

/* ── Tech specs ── */
.specs-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
  margin-bottom: 2rem;
}

.spec {
  background: var(--deep);
  padding: 1.8rem 1.5rem;
  text-align: center;
}

.spec-value {
  font-family: var(--display);
  font-weight: 700;
  font-size: 1.8rem;
  color: var(--white);
  margin-bottom: 0.3rem;
}

.spec-value.cyan { color: var(--cyan); }
.spec-value.amber { color: var(--amber); }
.spec-value.green { color: var(--green); }

.spec-label {
  font-size: 0.65rem;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.15em;
}

/* ── Footer ── */
footer {
  border-top: 1px solid var(--border);
  padding: 3rem 2rem;
  text-align: center;
}

.footer-ascii {
  font-family: var(--mono);
  font-size: 0.6rem;
  line-height: 1.3;
  color: var(--dim);
  white-space: pre;
  margin-bottom: 1.5rem;
}

.footer-links {
  display: flex;
  gap: 2rem;
  justify-content: center;
  margin-bottom: 1.5rem;
}

.footer-links a {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--muted);
  text-decoration: none;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  transition: color 0.3s;
}

.footer-links a:hover { color: var(--cyan); }

.footer-copy {
  font-size: 0.65rem;
  color: var(--dim);
  letter-spacing: 0.1em;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  .lore-block {
    grid-template-columns: 1fr;
  }
  .specs-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .lore-ascii {
    font-size: 0.4rem;
  }
}

/* ── Reveal animations ── */
.reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
</style>
</head>
<body>

<!-- Boot Sequence -->
<div class="boot-screen" id="bootScreen">
  <div class="boot-text" id="bootText"></div>
</div>

<!-- Starfield -->
<canvas id="starfield"></canvas>

<!-- Content -->
<div class="content" id="mainContent">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-ascii" id="heroAscii">
         .                    *           .        +
                  +                             .            .
     *       .          .    *    .                      *
          .       *                 +        .
   .          +          *              .          .     +
        *          .            .                *
              .         *    +         .    *
     +              .              *            .       *
          *    .          .    .         +          .
    .              *                .         *
         .    +          *    .         .            +
  *          .       .              *       .    *
        .         *          +    .              .
</div>
    <h1 class="hero-title" id="heroTitle">ASTRA</h1>
    <p class="hero-subtitle" id="heroSubtitle">A Sci-Fi Roguelike</p>
    <p class="hero-tagline" id="heroTagline">
      Command a starship. Explore the unknown.
      Navigate through <em>black holes</em>.
      Reach <em>Sagittarius&nbsp;A*</em> at the heart of the galaxy
      &mdash; or die trying.
    </p>
    <div class="hero-actions" id="heroActions">
      <a href="https://github.com/obscuren/astra/releases" class="btn">Download</a>
      <a href="https://github.com/obscuren/astra" class="btn secondary">Source Code</a>
    </div>
    <div class="scroll-indicator" id="scrollIndicator">Descend</div>
  </section>

  <hr class="section-divider">

  <!-- Lore -->
  <section>
    <div class="section-header">
      <span class="section-tag amber">LOG</span>
      <h2 class="section-title">The Journey</h2>
    </div>
    <div class="lore-block reveal">
      <div class="lore-text">
        <p>
          In the distant future, at the edge of explored space,
          <em>The Heavens Above</em> orbits Jupiter &mdash; a waystation
          for the desperate, the brave, and the mad.
        </p>
        <p>
          Adventurers dock their vessels, trade with alien merchants,
          and embark on an interstellar journey toward the center of
          the galaxy: <em>Sagittarius&nbsp;A*</em>, the supermassive
          black hole.
        </p>
        <p>
          Those who reach its event horizon are said to be
          reborn in a new universe, carrying with them the knowledge
          and scars of every previous life. But the path is treacherous
          &mdash; each star system generated uniquely, filled with
          hostile creatures, forgotten stations, and infinite darkness.
        </p>
        <p>
          <em>Death is permanent. Knowledge is eternal.</em>
        </p>
      </div>
      <div class="lore-ascii">
<span class="star">                          *</span>
                      .       .
                  .               .
              .        <span class="highlight">. . .</span>        .
           .       <span class="highlight">. .     . .</span>       .
         .      <span class="highlight">.               .</span>      .
        .     <span class="highlight">.    Sgr A*    .</span>     .
         .      <span class="highlight">.               .</span>      .
           .       <span class="highlight">. .     . .</span>       .
              .        <span class="highlight">. . .</span>        .
                  .               .
                      .       .
<span class="star">                          *</span>

        <span class="star">[  ACCRETION DISK — SGR A*  ]</span>
      <span class="star">   4.15 million solar masses   </span>
      <span class="star">   26,000 light-years distant  </span></div>
    </div>
  </section>

  <hr class="section-divider">

  <!-- Features -->
  <section>
    <div class="section-header">
      <span class="section-tag green">MOD</span>
      <h2 class="section-title">Systems</h2>
    </div>
    <div class="features-grid">
      <div class="feature-card reveal" data-index="01">
        <span class="feature-glyph">#</span>
        <div class="feature-name">Procedural Generation</div>
        <div class="feature-desc">Every asteroid, station, and dungeon is uniquely generated each playthrough. No two journeys to Sgr A* are the same.</div>
      </div>
      <div class="feature-card reveal" data-index="02">
        <span class="feature-glyph">@</span>
        <div class="feature-name">Character Creation</div>
        <div class="feature-desc">Choose from six races and five classes. Allocate attributes, name your character, and review your build before setting out into the void.</div>
      </div>
      <div class="feature-card reveal" data-index="03">
        <span class="feature-glyph">*</span>
        <div class="feature-name">Interstellar Navigation</div>
        <div class="feature-desc">Travel between star systems through black holes. Upgrade engines and navigation computers to reach more distant sectors.</div>
      </div>
      <div class="feature-card reveal" data-index="04">
        <span class="feature-glyph">&#x2692;</span>
        <div class="feature-name">Tinkering & Crafting</div>
        <div class="feature-desc">Repair, disassemble, analyze, and enhance equipment at the workbench. Learn blueprints and synthesize entirely new items from salvaged materials.</div>
      </div>
      <div class="feature-card reveal" data-index="05">
        <span class="feature-glyph">+</span>
        <div class="feature-name">Trading & Barter</div>
        <div class="feature-desc">Visit space stations to buy, sell, and barter with galactic merchants. Resources are scarce. Every transaction matters.</div>
      </div>
      <div class="feature-card reveal" data-index="06">
        <span class="feature-glyph">&#x2191;</span>
        <div class="feature-name">Skill Progression</div>
        <div class="feature-desc">Unlock eight skill categories &mdash; from blade mastery to persuasion. Spend skill points on passive bonuses and powerful active abilities.</div>
      </div>
      <div class="feature-card reveal" data-index="07">
        <span class="feature-glyph">X</span>
        <div class="feature-name">Ranged Combat</div>
        <div class="feature-desc">Engage hostile Xytomorphs and unknown threats with ranged weapons. Turn-based tactics demand every move counts.</div>
      </div>
      <div class="feature-card reveal" data-index="08">
