<script is:inline>
// ── Starfield ──
(() => {
  const canvas = document.getElementById('starfield');
  const ctx = canvas.getContext('2d');
  let stars = [];
  const STAR_COUNT = 200;
  const COLORS = ['#ffffff', '#aaccff', '#ffddaa', '#ffaaaa', '#aaffcc'];

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight * 5;
  }

  function init() {
    resize();
    stars = [];
    for (let i = 0; i < STAR_COUNT; i++) {
      stars.push({
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        size: Math.random() * 1.5 + 0.5,
        color: COLORS[Math.floor(Math.random() * COLORS.length)],
        twinkle: Math.random() * Math.PI * 2,
        speed: Math.random() * 0.02 + 0.005,
      });
    }
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const t = performance.now() / 1000;
    for (const s of stars) {
      const alpha = 0.3 + 0.7 * Math.abs(Math.sin(t * s.speed + s.twinkle));
      ctx.globalAlpha = alpha;
      ctx.fillStyle = s.color;
      ctx.beginPath();
      ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
    requestAnimationFrame(draw);
  }

  window.addEventListener('resize', () => { resize(); init(); });
  init();
  draw();
})();

// ── Boot sequence ──
(() => {
  const lines = [
    { text: 'ASTRA SYSTEMS v0.1.0', cls: '' },
    { text: 'Initializing subsystems...', cls: 'label' },
    { text: '  Navigation computer     [OK]', cls: 'ok' },
    { text: '  Shadowcasting engine    [OK]', cls: 'ok' },
    { text: '  Procedural generator    [OK]', cls: 'ok' },
    { text: '  Life support            [OK]', cls: 'ok' },
    { text: '  Weapons array           [OK]', cls: 'ok' },
    { text: '  Shield harmonics        [WARN: degraded]', cls: 'warn' },
    { text: 'Loading star charts... done.', cls: 'label' },
    { text: 'Connecting to The Heavens Above...', cls: 'label' },
    { text: '', cls: '' },
    { text: 'Welcome aboard, commander.', cls: '' },
  ];

  const container = document.getElementById('bootText');
  let i = 0;

  function addLine() {
    if (i >= lines.length) {
      const cursor = document.createElement('span');
      cursor.className = 'cursor-blink';
      container.appendChild(cursor);
      setTimeout(() => {
        document.getElementById('bootScreen').classList.add('done');
        document.body.classList.add('booted');
        revealHero();
      }, 800);
      return;
    }
    const div = document.createElement('div');
    div.className = 'line';
    if (lines[i].cls) {
      div.innerHTML = `<span class="${lines[i].cls}">${lines[i].text}</span>`;
    } else {
      div.textContent = lines[i].text;
    }
    container.appendChild(div);
    requestAnimationFrame(() => div.classList.add('visible'));
    i++;
    setTimeout(addLine, lines[i - 1].text === '' ? 100 : 120 + Math.random() * 80);
  }

  setTimeout(addLine, 500);
})();

// ── Hero reveal ──
function revealHero() {
  const ids = ['heroAscii', 'heroTitle', 'heroSubtitle', 'heroTagline', 'heroActions', 'scrollIndicator'];
  ids.forEach(id => document.getElementById(id).classList.add('visible'));
}

// ── Scroll reveal ──
(() => {
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
})();
</script>
